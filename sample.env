# ---------------------------------------------------------------------------
# ID My Pill - environment variables
#
# Copy this file to `.env` in the project root and fill in the values. The
# `.env` file is git-ignored and should never be committed.
# ---------------------------------------------------------------------------

# Django secret key (REQUIRED). Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Toggle Django debug mode. Leave as True for local development. The production
# settings module (idmypill_spl.settings_production) forces this off regardless.
DJANGO_DEBUG=True

# Base URL where pill images are served from (a static host or CDN). The hashed
# production image filenames produced by `build_production_images` are appended
# to this value.
PILL_IMAGES_URL=https://static.example.com/images/gsdb/

# ---------------------------------------------------------------------------
# Production only (used by idmypill_spl.settings_production)
# ---------------------------------------------------------------------------

# Comma-separated list of allowed hosts, e.g. api.yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=

# Postgres connection. Either supply a single DATABASE_URL...
# DATABASE_URL=postgres://user:password@host:5432/dbname
# ...or the individual settings below.
DJANGO_DATABASE_NAME=idmypill_spl
DJANGO_DATABASE_USER=postgres
DJANGO_DATABASE_PASSWORD=
DJANGO_DATABASE_HOST=localhost
DJANGO_DATABASE_PORT=5432
